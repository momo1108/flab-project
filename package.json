{
  "name": "flab-project",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "cross-env NODE_ENV=development APP_PHASE=local webpack serve --config webpack.dev.js",
    "build:staging": "cross-env NODE_ENV=production APP_PHASE=staging webpack --config webpack.prod.js",
    "build:production": "cross-env NODE_ENV=production APP_PHASE=production webpack --config webpack.prod.js --profile --json > stats.production.json",
    "type-check": "tsc -p ./tsconfig.build.json",
    "prepare": "husky install"
  },
  "sideEffects": [
    "*.css",
    "*.scss"
  ],
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "프론트엔드 개발 환경과 동작 방식을 공부하기 위한 레퍼지터리입니다.",
  "engines": {
    "node": ">=20.15.1"
  },
  "dependencies": {
    "core-js": "^3.49.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@babel/runtime-corejs3": "^7.29.2",
    "@eslint/js": "^9.39.4",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/webpack-env": "^1.18.8",
    "babel-loader": "^10.1.1",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "dotenv-webpack": "^9.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "globals": "^17.5.0",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.7",
    "husky": "^8.0.0",
    "lint-staged": "^16.4.0",
    "mini-css-extract-plugin": "^2.10.2",
    "postcss": "^8.5.10",
    "postcss-loader": "^8.2.1",
    "postcss-preset-env": "^11.2.1",
    "prettier": "^3.8.3",
    "react-refresh": "^0.18.0",
    "style-loader": "^4.0.0",
    "terser-webpack-plugin": "^5.5.0",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "webpack": "^5.106.2",
    "webpack-bundle-analyzer": "^5.3.0",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3",
    "webpack-merge": "^6.0.1"
  }
}
